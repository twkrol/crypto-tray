<?xml version='1.0' encoding='windows-1252'?>
<!--
  WiX installer manifest for Crypto Tray.
  Consumed by cargo-wix (https://github.com/volks73/cargo-wix), which
  passes $(var.Version) from Cargo.toml's package.version and
  $(var.CargoTargetBinDir) pointing at target/release.

  Static GUIDs below are intentional — they must remain stable across
  versions so Windows Installer can track upgrades. Regenerate ONLY if
  you ship a fundamentally different product under the same name.
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
  <Product
      Id='*'
      Name='Crypto Tray'
      UpgradeCode='5d8f3a72-9b1c-4e6f-a4d8-7c2b1a9e5f3d'
      Manufacturer='Tomek Król'
      Language='1033'
      Codepage='1252'
      Version='$(var.Version)'>

    <Package Id='*'
             Keywords='Installer'
             Description='Crypto Tray $(var.Version) installer'
             Manufacturer='Tomek Król'
             InstallerVersion='450'
             Languages='1033'
             Compressed='yes'
             InstallScope='perMachine'
             SummaryCodepage='1252'/>

    <MajorUpgrade Schedule='afterInstallInitialize'
                  DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

    <Media Id='1' Cabinet='media1.cab' EmbedCab='yes'/>

    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='ProgramFiles64Folder'>
        <Directory Id='APPLICATIONFOLDER' Name='Crypto Tray'>
          <Component Id='MainExecutable' Guid='7a3e9c2d-1f4b-4d8e-b9c1-6a3d2e5f8b1c' Win64='yes'>
            <File Id='exe0' Name='crypto-tray.exe'
                  Source='$(var.CargoTargetBinDir)\crypto-tray.exe' KeyPath='yes'/>
          </Component>
          <Component Id='LicenseFile' Guid='c1d2e3f4-a5b6-4c7d-be8f-0a1b2c3d4e5f' Win64='yes'>
            <File Id='LICENSE' Name='LICENSE.txt' Source='LICENSE' KeyPath='yes'/>
          </Component>
        </Directory>
      </Directory>

      <Directory Id='ProgramMenuFolder'>
        <Directory Id='ApplicationProgramsFolder' Name='Crypto Tray'>
          <Component Id='ApplicationShortcut' Guid='9b4c1f5a-2d8e-4f6c-a7b3-1d9e4c8f2b5a' Win64='yes'>
            <Shortcut Id='AppShortcut'
                      Name='Crypto Tray'
                      Description='Kursy kryptowalut w trayu'
                      Target='[APPLICATIONFOLDER]crypto-tray.exe'
                      WorkingDirectory='APPLICATIONFOLDER'/>
            <RemoveFolder Id='CleanUpShortcut' Directory='ApplicationProgramsFolder' On='uninstall'/>
            <RegistryValue Root='HKCU' Key='Software\CryptoTray' Name='installed' Type='integer' Value='1' KeyPath='yes'/>
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id='Binaries' Title='Application'
             Description='Installs the Crypto Tray application binaries and Start menu shortcut.'
             Level='1'
             ConfigurableDirectory='APPLICATIONFOLDER'
             AllowAdvertise='no'
             Display='expand'
             Absent='disallow'>
      <ComponentRef Id='MainExecutable'/>
      <ComponentRef Id='LicenseFile'/>
      <ComponentRef Id='ApplicationShortcut'/>
    </Feature>

    <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

    <!--
      On uninstall, scrub the HKCU autostart entry the app may have created
      from its tray menu. Custom action runs reg.exe in a deferred step with
      Impersonate='yes' so HKCU points at the invoking user's profile (and
      not LocalSystem's). Conditioned on REMOVE="ALL" so an upgrade does NOT
      remove the entry — only a full uninstall does. Return='ignore' keeps
      the uninstall going even if the registry value isn't there.
    -->
    <CustomAction Id='RemoveAutostartRunEntry'
                  Directory='APPLICATIONFOLDER'
                  ExeCommand='"[System64Folder]reg.exe" delete "HKCU\Software\Microsoft\Windows\CurrentVersion\Run" /v CryptoTray /f'
                  Execute='deferred'
                  Impersonate='yes'
                  Return='ignore'/>

    <InstallExecuteSequence>
      <Custom Action='RemoveAutostartRunEntry' After='InstallInitialize'>
        REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE
      </Custom>
    </InstallExecuteSequence>

    <!--
      Installer UI: WixUI_Minimal — single welcome+EULA dialog, then
      progress, then the exit dialog. The exit dialog gets an optional
      checkbox ("Launch Crypto Tray") wired to LaunchApplication via the
      Publish entry below. We only enable the checkbox on fresh install /
      upgrade (NOT UPGRADINGPRODUCTCODE is set during major-upgrade
      uninstall passes; we also keep REMOVE="" so the box never shows on
      a plain uninstall path).

      LaunchApplication runs the app under the invoking user with
      Return='asyncNoWait' so msiexec doesn't block waiting for the app
      to exit — the user clicks Finish and gets a running tray icon.
    -->
    <UIRef Id='WixUI_Minimal'/>
    <WixVariable Id='WixUILicenseRtf' Value='wix\License.rtf'/>

    <Property Id='WIXUI_EXITDIALOGOPTIONALCHECKBOX' Value='1'/>
    <Property Id='WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT' Value='Launch Crypto Tray'/>

    <CustomAction Id='LaunchApplication'
                  FileKey='exe0'
                  ExeCommand=''
                  Execute='immediate'
                  Impersonate='yes'
                  Return='asyncNoWait'/>

    <UI>
      <Publish Dialog='ExitDialog'
               Control='Finish'
               Event='DoAction'
               Value='LaunchApplication'>
        WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed and REMOVE=""
      </Publish>
    </UI>
  </Product>
</Wix>
